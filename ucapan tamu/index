<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Ucapan Tamu</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:#f5f5f5;
  font-family:Arial, sans-serif;
  padding:20px;
}

.title{
  text-align:center;
  font-size:28px;
  font-weight:bold;
  margin-bottom:25px;
  color:#333;
}

#data{
  display:flex;
  flex-direction:column;
  gap:15px;
}

.card{
  background:white;
  border-radius:20px;
  padding:18px;
  box-shadow:0 4px 15px rgba(0,0,0,0.08);
  animation:fadeIn 0.5s ease;
}

.nama{
  font-size:18px;
  font-weight:bold;
  color:#222;
}

.ucapan{
  margin-top:10px;
  line-height:1.6;
  color:#555;
}

.time{
  margin-top:12px;
  font-size:12px;
  color:#999;
}

.loading{
  text-align:center;
  color:#666;
}

@keyframes fadeIn{
  from{
    opacity:0;
    transform:translateY(10px);
  }
  to{
    opacity:1;
    transform:translateY(0);
  }
}

</style>

</head>

<body>

<div class="title">
Ucapan & Doa
</div>

<div id="data">
  <div class="loading">
    Memuat data...
  </div>
</div>

<script>

// GANTI DENGAN URL APPS SCRIPT KAMU
const apiUrl =
"https://script.google.com/macros/s/AKfycbzZv9M--UPx5gIx7nFLLcevGg-XzeUQRvTYvkROhkDtQGWJezGXKytVz48xBMzr4OEX/exec";

async function loadData(){

  try{

    const response = await fetch(apiUrl);

    const data = await response.json();

    let html = "";

    data.reverse().forEach(item => {

      html += `
        <div class="card">

          <div class="nama">
            ${item.NAMA || "-"}
          </div>

          <div class="ucapan">
            ${item["Tuliskan Ucapan Selamat & Doa"] || "-"}
          </div>

          <div class="time">
            ${item.Timestamp || ""}
          </div>

        </div>
      `;

    });

    document.getElementById("data").innerHTML = html;

  }catch(error){

    document.getElementById("data").innerHTML = `
      <div class="loading">
        Gagal mengambil data
      </div>
    `;

    console.log(error);

  }

}

// LOAD PERTAMA
loadData();

// AUTO REFRESH 5 DETIK
setInterval(() => {
  loadData();
}, 5000);

</script>

</body>
</html>
